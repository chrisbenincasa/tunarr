{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build-dev": {
      "dependsOn": ["^build"]
    },
    "clean-build": {
      "dependsOn": ["^build"]
    },
    "compile-messages": {
      "dependsOn": ["extract-messages"]
    },
    "dev": {
      "dependsOn": ["compile-messages"]
    },
    "extract-messages": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "bundle": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "generate-client": {
      "dependsOn": ["@tunarr/server#generate-openapi"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
